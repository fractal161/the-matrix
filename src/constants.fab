ct U GAME_SPRITE_PAL_AB = $01
ct U GAME_SPRITE_PAL_PIECE = $02
ct U GAME_SPRITE_PAL_HZ = $03

ct U SUBFRAME_RENDER_INPUT = $01
ct U SUBFRAME_CLEAR_INPUT = $02
ct U SUBFRAME_RENDER_DELAY = $04
