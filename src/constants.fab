ct UU[] points_bcd_table = UU[]($0000, $0040, $0100, $0300, $1200)

ct U RENDER_MENU_SCREEN = 0
ct U RENDER_GAME = 1
ct U RENDER_HIGH_SCORE_ENTRY = 2
ct U RENDER_VICTORY = 3
ct U RENDER_LEVEL_MENU = 4

ct U PLAY_STATE_GAME = 0
