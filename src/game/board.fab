// TODO: check that this is used efficiently (to minimize x10 usage)
fn board_set_cell(MM/board board, U x, U y, U tile)
: +inline
    board[TIMES_TEN_TABLE()[y] + x] = tile

// TODO: check that this is used efficiently (to minimize x10 usage)
fn board_get_cell(MM/board board, U x, U y) U
: +inline
    return board[TIMES_TEN_TABLE()[y] + x]
