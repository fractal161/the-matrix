ct Int NUM_SUBFRAMES = 8
// board height + 3, which is how many frames before we're tracking track
ct Int INPUT_STREAM_LENGTH = 23
// last entry is nmi poll, experimentally tested
ct U[NUM_SUBFRAMES] SCANLINES = U[](12, 45, 77, 110, 143, 175, 208, 241)

vars /game
    // normal pad only updates once a frame to preserve game logic
    Pad subframe_pad

    // lsb is start of frame, to make it easy to look up nmi bits
    // since we're not cleaning these up (expensive), we have to use
    // input_stream_index for all calculations
    U[INPUT_STREAM_LENGTH] lr_input_stream
    U[INPUT_STREAM_LENGTH] ab_input_stream
    // for doing diffs
    U lr_this_frame
    U lr_last_frame
    // TODO: we clean ALLLL of this up during either lock_piece or
    // check_for_completed_rows
    U input_stream_index = 0 // how many frames we've been tracking
    U subframe_index = 0 // 0-7
    U subframe_render_flags = 0


fn handle_subframe_nmi()
    // hack to clear interrupt so the subframe polls can run
    cli()
    {MMC5_SCANLINE_STATUS}($80)
    {MMC5_SCANLINE_COMPARE}(SCANLINES[0])
    // pads already polled, we only have to update
    subframe_pad = update_pad(subframe_pad, raw_pads[0])
    fence
    handle_subframe_poll()

irq subframe_poll()
    // acknowledge
    {MMC5_SCANLINE_STATUS}()
    fence
    // schedule next irq
    {MMC5_SCANLINE_COMPARE}(SCANLINES[subframe_index])
    poll_pads() // stored into raw_pads
    subframe_pad = update_pad(subframe_pad, raw_pads[0])
    fence
    handle_subframe_poll()

fn handle_subframe_poll()
    Bool is_lr_pressed = subframe_pad.held & (BUTTON_LEFT | BUTTON_RIGHT)
    // update polls this frame
    is_lr_pressed >=> lr_this_frame
    // update input stream
    if input_stream_index < INPUT_STREAM_LENGTH
        Bool is_ab_pressed = subframe_pad.held & (BUTTON_A | BUTTON_B)
        // "assign by rotate right" aka the coolest operation ever
        is_ab_pressed >=> ab_input_stream[input_stream_index]
        // then left/right
        is_lr_pressed >=> lr_input_stream[input_stream_index]
        subframe_render_flags |= SUBFRAME_RENDER_INPUT
        // don't increment input_stream_index here (it's updated during nmi)
    // update input delay
    set_breakpoint($6000)
    if is_lr_pressed && stat_input_delay == $FF
        // update stat_input_delay immediately because it's easy
        stat_input_delay = (input_stream_index << 3) + subframe_index
        subframe_render_flags |= SUBFRAME_RENDER_DELAY
    // end of frame tasks
    if subframe_index == NUM_SUBFRAMES - 1
        // can use lr_this_frame
    subframe_index += 1
    if subframe_index == NUM_SUBFRAMES
        subframe_index = 0
        fence
        update_hud_immediate()
        if input_stream_index < INPUT_STREAM_LENGTH
            input_stream_index += 1

// used in another state to reset vars
fn handle_subframe_cleanup()
: +inline
    // for U i = 0; i < INPUT_STREAM_LENGTH; i += 1
    //     ab_input_stream[i] = 0
    //     lr_input_stream[i] = 0
    input_stream_index = 0
    stat_input_delay = $FF
    lr_this_frame = 0
    lr_last_frame = 0

asm fn cli()
: employs
    cli
    rts

fn set_breakpoint(UU addr)
    {addr}($FF)

fn write_uu(UU addr, UU x)
    ppu_reset_addr(addr)
    fence
    {PPUDATA}(x.b >> 4)
    {PPUDATA}(x.b & %1111)
    {PPUDATA}(x.a >> 4)
    {PPUDATA}(x.a & %1111)
    fence
